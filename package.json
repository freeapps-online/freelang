{
  "name": "freelanguageapp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm --filter @freelanguageapp/web dev",
    "build": "pnpm --filter @freelanguageapp/web build",
    "seo:generate": "pnpm --filter @freelanguageapp/web seo:generate",
    "test": "pnpm --filter @freelanguageapp/web test",
    "preview": "pnpm --filter @freelanguageapp/web preview",
    "cf:deploy": "pnpm build && wrangler pages deploy web/dist",
    "cf:preview": "pnpm build && wrangler pages deploy web/dist --branch preview"
  },
  "devDependencies": {
    "wrangler": "^4.87.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeappstore-online/language.git"
  }
}
